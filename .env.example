# Realtime scanner does not need these keys.
# Fill these only when you are ready to test exchange account access.

EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_PASSWORD=

# Binance read-only connector credentials.
# These are only used for GET account/open-orders/order-history/trade-history endpoints.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
LIVE_TRADING=false

# Keep this false until paper trading and risk checks are proven.
LIVE_TRADING_ENABLED=false
LIVE_TRADING_DRY_RUN=true

# Required if you expose the API outside localhost.
BOT_API_KEY=change-this-long-random-token

# Dashboard/API bind. Keep localhost unless protected by reverse proxy/firewall.
BOT_API_HOST=127.0.0.1
BOT_API_PORT=8899
BOT_VERSION=1.0.0
TZ=UTC
PAPER_TRADING_ENABLED=true

# Optional Telegram control center placeholders.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
